DATABASE_URL=postgresql://user:password@localhost:5432/tickettoride
SECRET_KEY=change-me-to-something-random
FLASK_ENV=development

# Public URL of the site — used in notification links
SITE_URL=http://your-server-ip-or-domain

# Twilio SMS (optional — for text notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# SMTP Email (optional — for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Ticket to Ride <you@gmail.com>

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
